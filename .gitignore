# ─── Dependencies ──────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Env / secrets ─────────────────────────────────────────────────────────
# Never commit real secrets. .env.example at the root is the source of truth.
.env
.env.*
!.env.example

# ─── Build output ──────────────────────────────────────────────────────────
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# ─── Prisma generated client (custom output path) ──────────────────────────
backend/src/generated/

# ─── Logs / debug ──────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ─── Testing ───────────────────────────────────────────────────────────────
coverage/

# ─── Editor / OS ───────────────────────────────────────────────────────────
.DS_Store
*.pem
.vscode/
.idea/

# ─── Vercel ────────────────────────────────────────────────────────────────
.vercel

# ─── Local / scratch ───────────────────────────────────────────────────────
*.local
tmp/
