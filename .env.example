# ─── Database ──────────────────────────────────────────────────────────────
# Neon / Vercel Postgres / local Postgres. `cd backend && npm run db:push` applies schema.
DATABASE_URL="postgresql://user:pass@host:5432/sankofa"

# ─── AI (Vercel AI Gateway → Claude Sonnet 4.6) ────────────────────────────
# Get from https://vercel.com/dashboard/ai-gateway
AI_GATEWAY_API_KEY=""

# ─── CAMARA / Nokia Network-as-Code ────────────────────────────────────────
# Application key from https://networkascode.nokia.io application registration.
NAC_TOKEN=""
# "dev" | "staging" | empty for production. Sandbox test numbers: +99999991000 (swap), +99999991001 (no swap)
NAC_ENV="dev"

# ─── Email (Resend) ────────────────────────────────────────────────────────
# Get from https://resend.com/api-keys. Sandbox sender onboarding@resend.dev works without a verified domain.
RESEND_API_KEY=""

# ─── Mock bank (stands in for Opay / MTN MoMo / M-Pesa in the demo) ────────
# Defaults to http://localhost:3001/mock-bank/freeze when unset.
MOCK_BANK_URL=""

# ─── Server ────────────────────────────────────────────────────────────────
PORT="3001"
# Comma-separated extra origins allowed to call the backend (in addition to localhost and *.trycloudflare.com).
CORS_ORIGINS=""

# ─── Demo wiring ───────────────────────────────────────────────────────────
# Public base URL the undo / "found it" links in emails point back to.
# In dev this is the Next.js origin (the /api/* rewrite proxies through to the backend).
PUBLIC_APP_URL="http://localhost:3000"
# Seed addresses for the demo user (Kemi) and her trusted contact (Tunde).
DEMO_OWNER_EMAIL=""
DEMO_TRUSTED_EMAIL=""
# How often the location tracker polls CAMARA after a MEDIUM/HIGH event (ms). Default 30000.
LOCATION_POLL_MS="30000"

# ─── Frontend → backend proxy ──────────────────────────────────────────────
# Consumed by frontend/next.config.ts. Leave unset when running backend at localhost:3001.
BACKEND_URL=""
